# Public WalletConnect project id (optional but recommended)
# Get one at https://cloud.walletconnect.com — leave blank to disable WC.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Contract address (auto-set by deploy script via web/src/lib/deployment.ts).
# Override here only if you redeployed manually.
# NEXT_PUBLIC_CONTRACT_ADDRESS=0x...
